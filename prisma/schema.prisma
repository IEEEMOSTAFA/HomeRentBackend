// prisma/schema.prisma
// RentHome — Final Schema
// Auth pattern mirrors SkillBridge (BetterAuth: Account + Session + Verification)
// Role pattern mirrors SkillBridge (extension profile table for Owner, like TutorProfile)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN // Controls platform: approve/reject listings, ban users, manage blog
  OWNER // Posts and manages property listings, responds to bookings
  USER // Searches properties, makes bookings, pays, leaves reviews
  // Role is fixed at registration — only Admin can change it
}

enum PropertyType {
  FAMILY_FLAT
  BACHELOR_ROOM
  SUBLET
  HOSTEL
  OFFICE_SPACE
  COMMERCIAL
}

enum PropertyStatus {
  PENDING // Submitted by Owner, waiting for Admin approval
  APPROVED // Publicly visible
  REJECTED // Rejected by Admin with a written reason
}

enum AvailableFor {
  FAMILY
  BACHELOR
  CORPORATE
  ANY
}

enum BookingStatus {
  PENDING // USER submitted, waiting for OWNER response
  ACCEPTED // OWNER accepted, waiting for payment
  PAYMENT_PENDING // Stripe session created, not yet paid
  CONFIRMED // Payment successful — booking is live
  DECLINED // OWNER declined the request
  CANCELLED // USER cancelled before confirmation
}

enum PaymentStatus {
  PENDING // Stripe session initiated
  SUCCESS // Stripe confirmed payment
  FAILED // Stripe payment failed
  REFUNDED // Refunded after cancellation
}

// ─── BETTERAUTH MODELS ────────────────────────────────────────────────────────
// Keep identical structure to SkillBridge so BetterAuth works out of the box.

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  otp           String?
  otpExpiry     DateTime?
  image         String? // Profile photo URL (Cloudinary)
  role          UserRole  @default(USER) // Fixed at signup
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false) // Admin can ban harmful users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // BetterAuth relations (do not modify)
  accounts Account[]
  sessions Session[]

  // OWNER-only relations
  ownerProfile OwnerProfile?
  properties   Property[]

  // USER-only relations
  bookings Booking[] @relation("UserBookings")
  payments Payment[]
  reviews  Review[]  @relation("UserReviews")

  // ADMIN-only relations
  blogPosts BlogPost[]

  // Both USER and OWNER receive notifications
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([isBanned])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ─── RENTHOME MODELS ──────────────────────────────────────────────────────────

// Extension profile for OWNER — mirrors TutorProfile from SkillBridge.
// Created automatically when a user registers with role=OWNER.
// Deleted automatically if the Owner account is deleted (Cascade).
model OwnerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone      String?
  nidNumber  String? // National ID for verification
  verified   Boolean   @default(false) // Admin verifies the owner
  verifiedAt DateTime?

  // Stats (denormalized for fast dashboard queries — mirrors TutorProfile.rating)
  totalProperties Int   @default(0)
  totalEarnings   Float @default(0)
  rating          Float @default(0)
  totalReviews    Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("owner_profiles")
}

// Property posted by an OWNER.
// Cascade delete: if Owner is deleted → all their properties are deleted.
// Cascade delete: if Property is deleted → its Bookings, Reviews are deleted.
model Property {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title           String
  description     String         @db.Text
  type            PropertyType
  status          PropertyStatus @default(PENDING)
  rejectionReason String?        @db.Text // Written by Admin on rejection

  // Location
  city    String
  area    String
  address String @db.Text

  // Details
  bedrooms  Int    @default(0)
  bathrooms Int    @default(0)
  size      Float? // sqft, optional

  // Pricing
  rentAmount     Float
  advanceDeposit Float   @default(0)
  bookingFee     Float   @default(0) // Charged at booking confirmation
  isNegotiable   Boolean @default(false)

  // Availability
  availableFrom DateTime
  availableFor  AvailableFor @default(ANY)

  // Media — array of Cloudinary image URLs (up to 10)
  images String[]

  // Denormalized stats (updated on review/booking events)
  rating       Float @default(0)
  totalReviews Int   @default(0)
  views        Int   @default(0)

  publishedAt DateTime? // Stamped when Admin approves
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  bookings Booking[]
  reviews  Review[]

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([city, area])
  @@index([rentAmount])
  @@map("properties")
}

// Booking made by a USER for an APPROVED Property.
//
// Status flow:
//   PENDING → ACCEPTED → PAYMENT_PENDING → CONFIRMED
//           → DECLINED
//   PENDING / ACCEPTED → CANCELLED
//
// Mirror of SkillBridge Booking — same named relations pattern used.
model Booking {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)

  moveInDate      DateTime
  moveOutDate     DateTime?
  message         String?   @db.Text // Optional note from USER to OWNER
  numberOfTenants Int       @default(1)

  // Pricing snapshot at time of booking (immune to future rent changes)
  rentAmount  Float
  bookingFee  Float @default(0)
  totalAmount Float

  status           BookingStatus @default(PENDING)
  cancellationNote String?       @db.Text

  expiresAt   DateTime? // Auto-expire if Owner ignores for 24h
  confirmedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One payment and one review per booking (enforced by @unique on their FKs)
  payment       Payment?
  review        Review?
  notifications Notification[]

  @@index([propertyId])
  @@index([userId])
  @@index([status])
  @@map("bookings")
}

// Stripe payment — strictly one per Booking.
// Created when Booking moves to PAYMENT_PENDING.
model Payment {
  id        String  @id @default(cuid())
  bookingId String  @unique // One payment per booking
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  amount   Float
  currency String        @default("BDT")
  status   PaymentStatus @default(PENDING)

  // Stripe identifiers
  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique
  receiptUrl            String? // Stripe-hosted receipt link

  // Refund details (populated if booking is cancelled post-payment)
  refundAmount Float?    @default(0)
  refundedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payments")
}

// Review written by a USER after a CONFIRMED booking.
// Mirrors SkillBridge Review — same @unique bookingId guard (one review per booking).
// tutorId → tutorProfileId pattern reproduced here as propertyId + ownerProfileId.
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique // One review per booking
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  rating  Int // 1–5 stars
  comment String? @db.Text

  isFlagged Boolean @default(false) // Owner flags → Admin reviews
  isVisible Boolean @default(true) // Admin can hide without deleting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
  @@map("reviews")
}

// In-app notification for USER and OWNER.
// Triggered by: booking status changes, payment events, review flags.
// bookingId is nullable — system notifications won't have a booking.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  title     String
  message   String  @db.Text
  type      String // "booking_update" | "payment" | "review" | "system"
  isRead    Boolean @default(false)
  actionUrl String? // Frontend route to navigate when clicked

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Blog post authored by ADMIN only.
// Standalone content — no FK to properties or bookings.
model BlogPost {
  id       String @id @default(cuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title         String
  slug          String    @unique
  excerpt       String    @db.Text
  content       String    @db.Text
  featuredImage String?
  tags          String[]
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([slug])
  @@map("blog_posts")
}
