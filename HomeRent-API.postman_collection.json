{
  "info": {
    "name": "HomeRent API - Auth Testing",
    "description": "Complete API endpoints for HomeRent Authentication and User Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "User signup, login, logout endpoints",
      "item": [
        {
          "name": "Sign Up - USER Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sign-up",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sign-up"]
            },
            "description": "Sign up as a USER (can search properties, make bookings)"
          },
          "response": []
        },
        {
          "name": "Sign Up - OWNER Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Owner\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sign-up",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sign-up"]
            },
            "description": "Sign up as a USER first, then update role to OWNER"
          },
          "response": []
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.session && jsonData.session.token) {",
                  "        pm.environment.set(\"auth_token\", jsonData.session.token);",
                  "        console.log('✅ Auth token saved:', jsonData.session.token.substring(0, 20) + '...');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sign-in",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sign-in"]
            },
            "description": "Sign in with email and password. Automatically saves token to environment."
          },
          "response": []
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/session",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "session"]
            },
            "description": "Get current session details"
          },
          "response": []
        },
        {
          "name": "Sign Out",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/api/auth/sign-out",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "sign-out"]
            },
            "description": "Sign out from current session"
          },
          "response": []
        }
      ]
    },
    {
      "name": "👤 User Profile",
      "description": "User profile management endpoints",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get current authenticated user details including role and profile"
          },
          "response": []
        },
        {
          "name": "Update User Role to OWNER",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ Role updated to:', jsonData.data.role);",
                  "    console.log('ℹ️ OwnerProfile automatically created');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"OWNER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/update-role",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "update-role"]
            },
            "description": "Update user role from USER to OWNER. Automatically creates OwnerProfile if it doesn't exist."
          },
          "response": []
        },
        {
          "name": "Update User Role to USER",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/update-role",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "update-role"]
            },
            "description": "Update user role back to USER"
          },
          "response": []
        }
      ]
    },
